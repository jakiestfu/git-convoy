{
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli/parse-args": "jsr:@std/cli@1/parse-args",
    "@std/fmt/colors": "jsr:@std/fmt@1/colors"
  },
  "tasks": {
    "check": "deno check *.ts *.test.ts",
    "test": "deno test --allow-run --allow-read --allow-write --allow-env",
    "fmt": "deno fmt",
    "run": "deno run --allow-run=git,gh,open,xdg-open,explorer --allow-read --allow-write --allow-env --allow-net main.ts",
    "compile": "deno compile --allow-run=git,gh,open,xdg-open,explorer --allow-read --allow-write --allow-env --allow-net --output dist/git-dash main.ts"
  },
  "fmt": {
    "exclude": [
      "dist/"
    ]
  },
  "lint": {
    "exclude": [
      "dist/"
    ]
  }
}
